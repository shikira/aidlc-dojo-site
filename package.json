    "eslint": "10.6.0",
    "eslint-plugin-astro": "2.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "size-limit": "12.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.9",
    "yaml": "2.9.0"
