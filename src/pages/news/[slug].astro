---
// S7 — 記事 (/news/{slug}/). getStaticPaths enumerates CT-4 articles, so a
// non-existent slug is never generated and falls through to the 404 (UW-01) at
// runtime. Shares the S7 layout skeleton with the list. Renders a breadcrumb
// (新着 > title), the machine-readable date (A-5), the VersionTag, and the
// article body via <Content /> (Astro markdown render). No client JS.
import SharedLayout from '../../layouts/SharedLayout.astro';
import VersionTag from '../../components/VersionTag.astro';
import { t } from '../../i18n/t';
import { SITE_ORIGIN } from '../../config';
import { getCollection, render } from 'astro:content';
import { articleExcerpt } from '../../lib/articles';
import type { Article } from '../../lib/content/types';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const article: Article = {
  slug: entry.id,
  title: entry.data.title,
  date: entry.data.date,
  version: entry.data.version,
  body: entry.body ?? '',
};
const description = articleExcerpt(article, 140);
---

<SharedLayout
  title={`${article.title} — ${t('site.name')}`}
  description={description}
  canonicalUrl={`${SITE_ORIGIN}/news/${article.slug}/`}
>
  <article class="page">
    <nav class="breadcrumb" aria-label={t('nav.breadcrumb.aria')}>
      <ol>
        <li><a href="/">{t('site.name')}</a></li>
        <li><a href="/news/">{t('news.breadcrumb.list')}</a></li>
        <li aria-current="page">{article.title}</li>
      </ol>
    </nav>

    <header class="article-header">
      <h1>{article.title}</h1>
      <p class="article-meta">
        <time datetime={article.date}>
          <span class="visually-hidden">{t('news.article.dateLabel')}: </span>{
            article.date
          }
        </time>
        <VersionTag version={article.version} />
      </p>
    </header>

    <div class="article-body">
      <Content />
    </div>
  </article>
</SharedLayout>

<style>
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
    padding: 0;
    list-style: none;
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-inline-end: var(--space-2);
    color: var(--color-muted);
  }

  .article-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .article-header h1 {
    margin: 0 0 var(--space-3);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
</style>
