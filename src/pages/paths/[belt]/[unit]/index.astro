---
// UI-3 UnitPage — path-context variant (/paths/{belt}/{unit}/) — FR-1.4 / G-1.
//
// getStaticPaths enumerates every (path, unit) pair via UW-02 getRoutePairs.
// The page renders: a breadcrumb (帯 > 単元), the TOC, the unit body with a
// QuizBlock island after each h2 section (interleaveQuestions → UnitBody), and
// UnitNav (prev/next; graduation when next=null; path-head when prev=null —
// state derived by UW-01 resolveNavState). SharedLayout receives
// canonicalUrl=/units/{id}/ so this page declares the canonical UnitPage (G-2).
// No new client JS (S-1) — QuizBlock is the only island.
import SharedLayout from '../../../../layouts/SharedLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import TocDisclosure from '../../../../components/TocDisclosure.astro';
import UnitNav from '../../../../components/UnitNav.astro';
import UnitBody from '../../../../components/UnitBody.astro';
import VersionTag from '../../../../components/VersionTag.astro';
import { t } from '../../../../i18n/t';
import { SITE_ORIGIN } from '../../../../config';
import { getCollection, render } from 'astro:content';
import { loadCollections } from '../../../../lib/content/parse';
import { createContentModel } from '../../../../lib/content/model';
import { getRoutePairs, pathUnitUrl } from '../../../../lib/routes';
import { resolveNavState } from '../../../../lib/resolveNavState';
import { extractToc } from '../../../../lib/toc';
import {
  interleaveQuestions,
  splitSections,
} from '../../../../lib/pages/interleave';
import type { NavLink } from '../../../../components/contracts';

export async function getStaticPaths() {
  const model = createContentModel(loadCollections());
  const entries = await getCollection('units');
  const entryById = new Map(entries.map((entry) => [entry.id, entry]));

  return getRoutePairs(model).flatMap((route) => {
    if (route.kind !== 'path') {
      return [];
    }
    const entry = entryById.get(route.params.unitId);
    if (!entry) {
      throw new Error(
        `paths/[belt]/[unit]: no unit collection entry for "${route.params.unitId}".`,
      );
    }
    const { belt, unitId } = route.params;
    const { neighbors, path, canonicalUrl, unit } = route.props;
    const prev: NavLink | null = neighbors.prev
      ? {
          title: neighbors.prev.title,
          href: pathUnitUrl(belt, neighbors.prev.id),
        }
      : null;
    const next: NavLink | null = neighbors.next
      ? {
          title: neighbors.next.title,
          href: pathUnitUrl(belt, neighbors.next.id),
        }
      : null;
    return [
      {
        params: { belt, unit: unitId },
        props: {
          entry,
          belt,
          beltNameJa: path.nameJa,
          pathHref: `/paths/${belt}/`,
          canonicalPath: canonicalUrl,
          readingTimeMin: unit.readingTimeMin,
          version: unit.version,
          prev,
          next,
          questions: model.getQuestionsForUnit(unitId),
        },
      },
    ];
  });
}

const {
  entry,
  belt,
  beltNameJa,
  pathHref,
  canonicalPath,
  readingTimeMin,
  version,
  prev,
  next,
  questions,
} = Astro.props;

const { headings } = await render(entry);
const html = entry.rendered?.html;
if (!html) {
  throw new Error(
    `paths/[belt]/[unit]: unit "${entry.id}" has no rendered HTML.`,
  );
}

const items = interleaveQuestions(splitSections(html), questions);
const toc = extractToc(headings);
const navState = resolveNavState({ belt, beltNameJa, pathHref, prev, next });
const unitTitle = entry.data.title;
---

<SharedLayout
  title={`${unitTitle} — ${t('site.name')}`}
  description={`${unitTitle}${t('page.unit.descriptionSuffix')}`}
  canonicalUrl={`${SITE_ORIGIN}${canonicalPath}`}
>
  <article class="unit-page">
    <Breadcrumb
      belt={belt}
      beltNameJa={beltNameJa}
      beltHref={pathHref}
      unitTitle={unitTitle}
    />

    <header class="unit-header">
      <h1>{unitTitle}</h1>
      <p class="unit-meta">
        <VersionTag version={version} />
        <span class="unit-meta__reading">
          <span class="visually-hidden">{t('reading.time.label')}: </span>
          <time datetime={`PT${readingTimeMin}M`}
            >{readingTimeMin}{t('reading.time.unit')}</time
          >
        </span>
      </p>
    </header>

    <TocDisclosure entries={toc} />
    <UnitBody items={items} />
    <UnitNav state={navState} />
  </article>
</SharedLayout>

<style>
  .unit-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .unit-header h1 {
    margin: 0 0 var(--space-3);
  }

  .unit-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
</style>
