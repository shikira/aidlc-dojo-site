---
// UI-1 TopPage (/) — the three-door top (M1 / US-R1-01 / FR-3.1).
//
// Composes UW-01 BeltCard × 3 (belt meta + unit count + summed reading time),
// a news teaser of the newest 3 articles (HIDDEN when empty — B-3), and a
// permanent roadmap row (→ UW-05 /roadmap/). All data comes from UW-02 queries;
// all labels route through t() (S-2). No client JS (S-1) — the only island on
// the site is QuizBlock, which this page does not mount.
import SharedLayout from '../layouts/SharedLayout.astro';
import BeltCard from '../components/BeltCard.astro';
import VersionTag from '../components/VersionTag.astro';
import { t } from '../i18n/t';
import { SITE_ORIGIN } from '../config';
import { loadCollections } from '../lib/content/parse';
import { createContentModel } from '../lib/content/model';
import { pathTotalReadingMin } from '../lib/pages/reading';
import { latestArticles } from '../lib/pages/articles';
import { articleExcerpt } from '../lib/articles';
import { BELTS } from '../lib/content/types';
import type { BeltCardProps } from '../components/contracts';

const model = createContentModel(loadCollections());

// White → brown → black (learning order), not the alphabetical file order.
const belts: BeltCardProps[] = [...model.getAllPaths()]
  .sort((a, b) => BELTS.indexOf(a.belt) - BELTS.indexOf(b.belt))
  .map((path) => {
    const units = model.getUnitsForPath(path.belt);
    return {
      belt: path.belt,
      nameJa: path.nameJa,
      nameEn: path.nameEn,
      audience: path.audience,
      unitCount: units.length,
      totalReadingMin: pathTotalReadingMin(units),
      href: `/paths/${path.belt}/`,
    };
  });

const teaser = latestArticles(model.getArticles(), 3);
---

<SharedLayout
  title={t('page.home.title')}
  description={t('page.home.description')}
  canonicalUrl={`${SITE_ORIGIN}/`}
>
  <section class="hero">
    <h1>{t('page.home.h1')}</h1>
    <p class="hero__subtitle">{t('page.home.hero.subtitle')}</p>
    <a class="hero__cta" href="#belts" data-testid="home-cta"
      >{t('page.home.hero.cta')}</a
    >
  </section>

  <section id="belts" class="belts" aria-labelledby="belts-heading">
    <h2 id="belts-heading">{t('page.home.belts.heading')}</h2>
    <p class="belts__intro">{t('page.home.belts.intro')}</p>
    <div class="belts__grid">
      {belts.map((belt) => <BeltCard {...belt} />)}
    </div>
  </section>

  {
    teaser.length > 0 && (
      <section class="news-teaser" aria-labelledby="news-teaser-heading">
        <h2 id="news-teaser-heading">{t('page.home.news.heading')}</h2>
        <div class="news-teaser__list">
          {teaser.map((article) => (
            <article class="teaser-card">
              <p class="teaser-card__meta">
                <time datetime={article.date}>
                  <span class="visually-hidden">
                    {t('news.article.dateLabel')}:{' '}
                  </span>
                  {article.date}
                </time>
                <VersionTag version={article.version} />
              </p>
              <h3 class="teaser-card__title">
                <a href={`/news/${article.slug}/`}>{article.title}</a>
              </h3>
              <p class="teaser-card__excerpt">{articleExcerpt(article)}</p>
            </article>
          ))}
        </div>
        <a class="news-teaser__all" href="/news/" data-testid="news-view-all">
          {t('page.home.news.viewAll')}
        </a>
      </section>
    )
  }

  <section class="roadmap-row" aria-labelledby="roadmap-row-heading">
    <h2 id="roadmap-row-heading">{t('page.home.roadmap.heading')}</h2>
    <p>{t('page.home.roadmap.body')}</p>
    <a href="/roadmap/" data-testid="roadmap-row-link"
      >{t('page.home.roadmap.link')}</a
    >
  </section>
</SharedLayout>

<style>
  .hero {
    padding: var(--space-6) 0;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .hero h1 {
    margin: 0 0 var(--space-3);
    font-size: var(--font-size-xl);
  }

  .hero__subtitle {
    margin: 0 0 var(--space-5);
    color: var(--color-muted);
  }

  .hero__cta {
    display: inline-block;
    padding: var(--space-3) var(--space-5);
    background: var(--accent);
    color: var(--accent-contrast);
    border-radius: var(--radius);
    font-weight: 700;
    text-decoration: none;
  }

  .belts {
    margin-top: var(--space-6);
    scroll-margin-top: var(--space-4);
  }

  .belts__intro {
    margin: 0 0 var(--space-4);
    color: var(--color-muted);
  }

  .belts__grid {
    display: grid;
    gap: var(--space-4);
  }

  .news-teaser,
  .roadmap-row {
    margin-top: var(--space-8);
  }

  .news-teaser__list {
    margin: var(--space-4) 0;
  }

  .teaser-card {
    padding: var(--space-4) 0;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .teaser-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-2);
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .teaser-card__title {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-lg);
  }

  .teaser-card__excerpt {
    margin: 0;
    color: var(--color-fg);
  }
</style>
