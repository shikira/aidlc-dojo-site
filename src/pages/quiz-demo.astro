---
// quiz-demo.astro — TEMPORARY construction demo (UW-03).
//
// It mounts ONE QuizBlock with a real CT-3 sample question (via the UW-02
// content collection) so the island chunk is actually built — that lets us
// measure its bundle (size-limit, R-B) and inspect the built HTML for the CSP ×
// hydration check (R-A). UW-04 OWNS real page composition and WILL REPLACE this
// page; do not build features on it. Labels are resolved here through t() and
// passed as props (I3) — the island never calls t() itself.
import SharedLayout from '../layouts/SharedLayout.astro';
import QuizBlock from '../components/QuizBlock.astro';
import { getCollection } from 'astro:content';
import { t } from '../i18n/t';
import type { QuizLabels } from '../components/quiz/contracts';

const questions = await getCollection('questions');
const sample =
  questions.find((entry) => entry.id === 'q-what-is-aidlc-1') ?? questions[0];
if (!sample) {
  throw new Error(
    'quiz-demo: no sample question found in the questions collection.',
  );
}
const question = sample.data;

const labels: QuizLabels = {
  submit: t('quiz.action.submit'),
  retry: t('quiz.action.retry'),
  correct: t('quiz.result.correct'),
  incorrect: t('quiz.result.incorrect'),
  correctSymbol: t('quiz.symbol.correct'),
  incorrectSymbol: t('quiz.symbol.incorrect'),
  explanationLabel: t('quiz.label.explanation'),
  sourceLabel: t('quiz.label.source'),
  externalNote: t('quiz.label.external'),
  noscript: t('quiz.noscript.message'),
};
---

<SharedLayout
  title={t('page.quizdemo.title')}
  description={t('page.quizdemo.description')}
>
  <section class="quiz-demo">
    <h1>{t('page.quizdemo.heading')}</h1>
    <p>{t('page.quizdemo.note')}</p>
    <QuizBlock
      questionId={question.id}
      prompt={question.prompt}
      choices={question.choices}
      answerIndex={question.answerIndex}
      explanation={question.explanation}
      sourceUrl={question.sourceUrl}
      labels={labels}
    />
  </section>
</SharedLayout>
