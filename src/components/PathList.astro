---
// PathList (C3) — the ordered unit list on a PathPage (UI-2 / US-R1-03).
//
// UW-01 froze `PathListProps` in components/contracts.ts but shipped no
// component; this is the minimal, tokens-only implementation. Semantics: a
// `nav` landmark wrapping an ordered list (`ol`) so the learning ORDER is
// conveyed to assistive tech (A-1). Each row is a single link to the unit's
// path-context URL; it shows the position number, title, VersionTag (colour +
// text, S-6), and a machine-readable reading time (`<time>`, S-5). No client JS.
import { t } from '../i18n/t';
import VersionTag from './VersionTag.astro';
import type { PathListProps } from './contracts';

type Props = PathListProps;

const { belt, items, currentUnitId } = Astro.props;
---

<nav
  class="path-list"
  data-belt={belt}
  aria-label={t('nav.pathlist.aria')}
  data-testid="path-list"
>
  <ol class="path-list__items">
    {
      items.map((item, index) => (
        <li
          class="path-list__item"
          aria-current={item.unitId === currentUnitId ? 'true' : undefined}
        >
          <a
            class="path-list__link"
            href={item.href}
            data-testid={`path-list-link-${item.unitId}`}
          >
            <span class="path-list__number" aria-hidden="true">
              {index + 1}
            </span>
            <span class="path-list__body">
              <span class="path-list__title">
                <span class="visually-hidden">
                  {t('pathlist.unitNumber.label')}: {index + 1}.{' '}
                </span>
                {item.title}
              </span>
              <span class="path-list__tags">
                <VersionTag version={item.version} />
                <span class="path-list__reading">
                  <span class="visually-hidden">
                    {t('reading.time.label')}:{' '}
                  </span>
                  <time datetime={`PT${item.readingTimeMin}M`}>
                    {item.readingTimeMin}
                    {t('reading.time.unit')}
                  </time>
                </span>
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .path-list__items {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: none;
  }

  .path-list__item {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .path-list__link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-2);
    text-decoration: none;
    color: var(--color-fg);
  }

  .path-list__link:hover,
  .path-list__link:focus-visible {
    background: var(--color-surface);
  }

  .path-list__number {
    flex: 0 0 auto;
    min-width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    font-weight: 700;
    font-size: var(--font-size-sm);
  }

  .path-list__body {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
  }

  .path-list__title {
    flex: 1 1 12rem;
    font-weight: 700;
  }

  .path-list__tags {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .path-list__item[aria-current='true'] .path-list__link {
    background: var(--color-surface);
  }
</style>
